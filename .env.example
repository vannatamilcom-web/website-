# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# YouTube Data API v3 (optional): used to fetch latest videos / live video id.
# WARNING: Any VITE_* variable is bundled into the frontend and is visible to users.
# Prefer proxying via a backend if you need to keep the key private.
VITE_YOUTUBE_API_KEY="YOUR_YOUTUBE_API_KEY"
VITE_YOUTUBE_CHANNEL_ID="YOUR_CHANNEL_ID"

# Optional override: if set, Live TV page will embed this video id directly.
VITE_YOUTUBE_LIVE_VIDEO_ID=""

# Facebook Page (public): used to embed the Page timeline (no access token required).
# Facebook URL (public): used for outbound "Facebook" links (can be a share link).
VITE_FACEBOOK_URL="https://www.facebook.com/share/1AwyG5Yq7w/"

# Example Page URL: "https://www.facebook.com/YourPageName" (recommended)
# Note: Facebook's timeline embed works for Pages, not personal profiles (profile.php?id=...).
VITE_FACEBOOK_PAGE_URL=""

# Instagram profile (public): used for outbound Instagram links.
VITE_INSTAGRAM_URL="https://www.instagram.com/"

# --- Facebook Graph API (build-time only; never VITE_*) ---
# Used by scripts/fetch-facebook-posts.mjs to generate public/facebook-posts.json during deploy.
FACEBOOK_PAGE_ID=""
# Preferred order:
# 1. FB_LONG_TOKEN to derive the page token during build
# 2. FB_PAGE_TOKEN if you already have a page access token
FB_LONG_TOKEN=""
FB_PAGE_TOKEN=""
FACEBOOK_GRAPH_VERSION="v20.0"
FACEBOOK_POST_LIMIT="12"

# --- Instagram API (server/build-time only; never VITE_*) ---
# Used by scripts/fetch-instagram-posts.mjs to generate public/instagram-posts.json during CI build.
# Token should be stored only in GitHub Secrets.
INSTAGRAM_ACCESS_TOKEN=""
# Optional: if you use the Instagram Graph API (Business/Creator), set the IG User ID.
INSTAGRAM_USER_ID=""
INSTAGRAM_GRAPH_VERSION="v20.0"
INSTAGRAM_POST_LIMIT="12"
